# ── ClearBudget environment variables ─────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Flask
SECRET_KEY=change-me-in-production

# Database (defaults to SQLite at backend/budgeting.db — fine for local dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/clearbudget

# ── Plaid sandbox ──────────────────────────────────────────────────────────
# 1. Sign up at https://dashboard.plaid.com/signup (free sandbox account)
# 2. Create an app → copy client_id and sandbox secret below
# 3. Set PLAID_ENV=sandbox for testing (no real bank credentials needed)
#
# Leave these blank to run the app without Plaid — all other features work normally.

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Future providers (not yet implemented) ─────────────────────────────────
# FLINKS_CLIENT_ID=
# FLINKS_API_KEY=
# FLINKS_ENV=sandbox
